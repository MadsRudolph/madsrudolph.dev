---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { categories, projectCategoryKeys } from '../../../projectCategories';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order || b.data.date.valueOf() - a.data.date.valueOf()
);

const used = new Set(projects.flatMap((p) => projectCategoryKeys(p.data.tags)));
const shownCategories = categories.filter((c) => used.has(c.key));
---

<Base
  title="Projekter — Mads Rudolph"
  description="Hardware- og firmware-projekter: PCB-fabrikation, ESP32-firmware, reverse engineering og laboratorieværktøj. Filtrér efter kompetence."
  lang="da"
  altUrl="/projects"
>
  <div class="page-head">
    <span class="label">Oversigt</span>
    <h1>Projekter</h1>
    <p class="lede">
      Filtrér efter værktøj eller kompetence. Hver beskrivelse følger samme struktur: hvad det er,
      hvordan det er bygget, hvad der gik galt, og hvad der kom ud af det.
    </p>
    <p style="color: var(--muted); font-size: 0.9rem;">
      De uddybende projektbeskrivelser er skrevet på engelsk.
    </p>
  </div>

  <div class="filter-bar" id="filter-bar" hidden>
    <button type="button" data-tag="" aria-pressed="true">alle</button>
    {
      shownCategories.map((c) => (
        <button type="button" data-tag={c.key} aria-pressed="false">
          {c.da}
        </button>
      ))
    }
    <span class="filter-sep" aria-hidden="true"></span>
    <button type="button" data-tag="personal" aria-pressed="false">Personlige</button>
    <button type="button" data-tag="coursework" aria-pressed="false">Kursusprojekter</button>
  </div>

  <ul class="project-list" id="project-list">
    {
      projects.map((project, i) => (
        <ProjectCard
          project={project}
          index={i}
          lang="da"
          filterTags={[...projectCategoryKeys(project.data.tags), project.data.kind]}
        />
      ))
    }
  </ul>

  <script>
    const bar = document.getElementById('filter-bar')!;
    const cards = document.querySelectorAll<HTMLElement>('#project-list .project-card');
    bar.hidden = false;

    bar.addEventListener('click', (event) => {
      const button = (event.target as HTMLElement).closest('button');
      if (!button) return;
      const tag = button.dataset.tag ?? '';
      for (const other of bar.querySelectorAll('button')) {
        other.setAttribute('aria-pressed', String(other === button));
      }
      for (const card of cards) {
        const tags = (card.dataset.tags ?? '').split(',');
        card.style.display = !tag || tags.includes(tag) ? '' : 'none';
      }
    });
  </script>
</Base>
