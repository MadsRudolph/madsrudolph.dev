---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { categories, projectCategoryKeys } from '../../projectCategories';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order || b.data.date.valueOf() - a.data.date.valueOf()
);

// Only show filter buttons for categories that actually have projects.
const used = new Set(projects.flatMap((p) => projectCategoryKeys(p.data.tags)));
const shownCategories = categories.filter((c) => used.has(c.key));
---

<Base
  title="Projects — Mads Rudolph"
  description="Hardware and firmware projects: PCB fabrication, ESP32 firmware, reverse engineering, and lab tooling. Filter by skill."
  lang="en"
  altUrl="/da/projects"
>
  <div class="page-head">
    <span class="label">Index</span>
    <h1>Projects</h1>
    <p class="lede">
      Filter by tool or skill. Every writeup follows the same structure: what it is, how it's
      built, what went wrong, and what came out of it.
    </p>
  </div>

  <div class="filter-bar" id="filter-bar" hidden>
    <button type="button" data-tag="" aria-pressed="true">all</button>
    {
      shownCategories.map((c) => (
        <button type="button" data-tag={c.key} aria-pressed="false">
          {c.en}
        </button>
      ))
    }
  </div>

  <ul class="project-list" id="project-list">
    {
      projects.map((project, i) => (
        <ProjectCard project={project} index={i} filterTags={projectCategoryKeys(project.data.tags)} />
      ))
    }
  </ul>

  <script>
    // Progressive enhancement: tag filter. Without JS the full list renders.
    const bar = document.getElementById('filter-bar')!;
    const cards = document.querySelectorAll<HTMLElement>('#project-list .project-card');
    bar.hidden = false;

    bar.addEventListener('click', (event) => {
      const button = (event.target as HTMLElement).closest('button');
      if (!button) return;
      const tag = button.dataset.tag ?? '';
      for (const other of bar.querySelectorAll('button')) {
        other.setAttribute('aria-pressed', String(other === button));
      }
      for (const card of cards) {
        const tags = (card.dataset.tags ?? '').split(',');
        card.style.display = !tag || tags.includes(tag) ? '' : 'none';
      }
    });
  </script>
</Base>
