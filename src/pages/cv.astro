const skillGroups = [
  {
    label: 'Hardware',
    items: ['KiCad (schematic, footprint creation, PCB layout)', 'PCB fabrication (fiber laser, CNC mill, reflow)', 'Analog & digital electronics', 'Fusion 360 CAD'],
  },
  {
    label: 'Firmware & software',
    items: ['C / Embedded C', 'ESP32 (ESP-IDF, ESPHome)', 'Python', 'Git'],
