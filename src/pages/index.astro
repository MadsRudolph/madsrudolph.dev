---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = await getCollection('projects');
const featured = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<Base
  title="Mads Rudolph — electronics engineering student, DTU"
  description="Portfolio of Mads Rudolph: PCB design, embedded firmware, and electronics debugging. Seeking an engineering internship (praktik) from January 2027."
  lang="en"
  altUrl="/da"
>
  <section class="hero">
    <h1>Mads Rudolph<span class="accent">.</span><span class="caret" aria-hidden="true"></span></h1>

    <div class="scope" aria-hidden="true">
      <span class="scope-tag">step response · closed loop</span>
      <span class="scope-legend"><span class="ch1">CH1</span><span class="ch2">CH2</span></span>
      <svg viewBox="0 0 1200 118" preserveAspectRatio="none" role="presentation">
        <!-- CH1: underdamped step response — steps up, overshoots, rings, and
             settles at the new (higher) reference level. (y grows downward.) -->
        <path
          class="scope-trace ch1"
          d="M0,95 L300,95 C352,95 378,22 430,22 C482,22 508,56 560,56 C612,56 638,34 690,34 C742,34 768,48 820,48 C872,48 898,42 950,42 L1200,42"
        />
        <!-- CH2: a more heavily-damped second channel settling just below CH1 -->
        <path
          class="scope-trace ch2"
          d="M0,100 L308,100 C360,100 386,33 448,33 C510,33 512,60 570,60 C628,60 632,45 692,46 C760,47 800,48 1200,48"
        />
      </svg>
    </div>

    <p class="status-line">
      <span class="dot" aria-hidden="true"></span>
      seeking praktik from Jan 2027 · open to student jobs
    </p>

    <ul class="specs">
      <li><b>DTU</b> · Elektroteknologi (B.Eng.)</li>
      <li>PCB · Embedded · Debugging</li>
      <li><b>AI</b> in the loop</li>
      <li>Kgs. Lyngby, DK</li>
    </ul>

    <div class="hero-summary">
      <p>I build and debug real hardware. This site is the evidence:</p>
      <ul class="hero-bullets">
        <li><strong>PCB Design & Fabrication:</strong> From KiCad to my own CNC/fiber-laser workflow.</li>
        <li><strong>Embedded Firmware:</strong> C/C++ on ESP32 that runs for months.</li>
        <li><strong>Bench Verification:</strong> Every project details the bugs, the tools, and the fix.</li>
      </ul>
      <div class="hero-actions">
        <a href="/cv" class="btn primary">View Full CV</a>
        <a href="mailto:mads28122001@hotmail.dk" class="btn secondary">Email Me</a>
      </div>
    </div>

    <p class="dansk" lang="da" style="margin-top: 1.5rem;">
      Jeg er diplomingeniørstuderende i Elektroteknologi på DTU og søger praktikplads fra januar
      2027 samt studiejob inden for elektronik og embedded udvikling. Skriv gerne på engelsk
      eller dansk.
    </p>
  </section>

  <div class="section-rule"><span class="label">Hardware Toolbox</span></div>
  <div class="skills-matrix">
    <div class="skill-category">
      <h3>Hardware & PCBs</h3>
      <ul>
        <li>KiCad (Schematic & Layout)</li>
        <li>Fiber Laser & CNC Fab</li>
        <li>Analog & Digital Circuits</li>
        <li>Power Electronics</li>
      </ul>
    </div>
    <div class="skill-category">
      <h3>Firmware & Software</h3>
      <ul>
        <li>C / C++ (Embedded)</li>
        <li>ESP32 / ESP-IDF</li>
        <li>Python</li>
        <li>Digital Signal Processing</li>
      </ul>
    </div>
    <div class="skill-category">
      <h3>Bench & Debugging</h3>
      <ul>
        <li>Oscilloscopes & Logic Analyzers</li>
        <li>Protocol Reverse Engineering</li>
        <li>Hardware/Firmware Integration</li>
        <li>Failure Diagnosis</li>
      </ul>
    </div>
  </div>

  <div class="section-rule"><span class="label">Featured projects</span></div>
  <ul class="project-list">
    {featured.map((project, i) => <ProjectCard project={project} index={i} />)}
  </ul>
  <p style="margin-top: 1.25rem;">
    <a href="/projects">All projects →</a>
  </p>

  <div class="section-rule"><span class="label">Contact</span></div>
  <p>
    Email: <a href="mailto:mads28122001@hotmail.dk">mads28122001@hotmail.dk</a> ·
    GitHub: <a href="https://github.com/MadsRudolph">MadsRudolph</a> ·
    <a href="https://www.linkedin.com/in/mads-rudolph-65103a178/">LinkedIn</a>
  </p>
</Base>
