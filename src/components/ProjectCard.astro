---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '../i18n';

interface Props {
  project: CollectionEntry<'projects'>;
  index?: number;
  lang?: Lang;
  /** Show the project's hero image as a thumbnail (used on the home featured grid). */
  image?: boolean;
  /** Values put in data-tags for the index filter (broad categories). Defaults to the raw tags. */
  filterTags?: string[];
}

const { project, index, lang = 'en', image = false, filterTags } = Astro.props;
const { title, summary, date, tags, status, flagship, hero, heroAlt } = project.data;
const dataTags = (filterTags ?? tags).join(',');

const flagshipLabel = lang === 'da' ? 'flagskib' : 'flagship';

const locale = lang === 'da' ? 'da-DK' : 'en-GB';
const dateLabel = date.toLocaleDateString(locale, { year: 'numeric', month: 'short' });

const statusLabels = {
  en: { working: 'working', 'in-progress': 'in progress', archived: 'archived' },
  da: { working: 'fungerer', 'in-progress': 'i gang', archived: 'arkiveret' },
};
const statusLabel = statusLabels[lang][status];

// Writeups are English-only, so cards always link to the English page.
const idx = typeof index === 'number' ? String(index + 1).padStart(2, '0') : null;
---

<li class:list={['project-card', { flagship, 'has-thumb': image && hero }]} data-tags={dataTags}>
  {
    image && hero && (
      <a class="card-thumb" href={`/projects/${project.id}`} tabindex="-1" aria-hidden="true">
        <img src={hero} alt={heroAlt ?? ''} loading="lazy" />
      </a>
    )
  }
  <div class="meta">
    {idx && <span class="idx">{idx}</span>}
    {flagship && <span class="flag">★ {flagshipLabel}</span>}
    <span class="label">{dateLabel}</span>
    <span class="spacer"></span>
    <span class="status" data-status={status}>
      <span class="led" aria-hidden="true"></span>
      {statusLabel}
    </span>
  </div>
  <h3><a href={`/projects/${project.id}`}>{title}</a></h3>
  <p>{summary}</p>
  <div class="tags">
    {tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>
</li>
