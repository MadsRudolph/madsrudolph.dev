---
import stats from '../data/repo-stats.json';

interface Props {
  /** Full GitHub URL from project frontmatter, e.g. https://github.com/MadsRudolph/srm-cam */
  repo?: string;
}

const { repo } = Astro.props;

// Resolve "https://github.com/owner/name" (or "owner/name") to the stats key.
const key = repo?.replace(/^https?:\/\/github\.com\//, '').replace(/\/$/, '');
const data = key ? (stats as Record<string, any>)[key] : undefined;

const fmt = (n: number) => {
  if (n < 1000) return String(n);
  if (n < 1_000_000) return n < 100_000 ? `${(n / 1000).toFixed(1)}k` : `${Math.round(n / 1000)}k`;
  return `${(n / 1_000_000).toFixed(1)}M`;
};

const solo = data && data.contributors === 1;
const lead = data?.contributorList?.[0];
---

{
  data && (
    <aside class="glass-card repo-stats" aria-label="Repository statistics">
      <div class="rs-head">
        <span class="rs-tag">Repository</span>
        <a class="rs-link" href={data.url} target="_blank" rel="noopener">
          {key} ↗
        </a>
      </div>

      <div class="rs-grid">
        <div class="rs-stat">
          <span class="rs-num">{fmt(data.commits)}</span>
          <span class="rs-label">{data.commits === 1 ? 'commit' : 'commits'}</span>
        </div>

        <div class="rs-stat">
          <span class="rs-num">{data.language ?? '—'}</span>
          <span class="rs-label">language</span>
        </div>

        {solo ? (
          <div class="rs-stat rs-solo">
            {lead && <img class="rs-solo-avatar" src={lead.avatarUrl} alt={lead.login} width="34" height="34" loading="lazy" />}
            <span class="rs-label">solo build</span>
          </div>
        ) : (
          <div class="rs-stat">
            <span class="rs-num">{fmt(data.contributors)}</span>
            <span class="rs-label">contributors</span>
          </div>
        )}
      </div>

      {!solo && data.contributorList?.length > 0 && (
        <div class="rs-people">
          <div class="rs-avatars">
            {data.contributorList.slice(0, 8).map((c: any) => (
              <a href={c.htmlUrl} target="_blank" rel="noopener" title={`${c.login} · ${c.contributions} commits`}>
                <img src={c.avatarUrl} alt={c.login} width="26" height="26" loading="lazy" />
              </a>
            ))}
          </div>
          <span class="rs-people-label">{data.contributorList.map((c: any) => c.login).join(', ')}</span>
        </div>
      )}
    </aside>
  )
}
